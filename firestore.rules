rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      // Note: Google Auth users are verified by default. 
      // Password users would need link verification.
      return isSignedIn() && (request.auth.token.provider_id == 'google.com' || request.auth.token.email_verified == true);
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profiles
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      
      function isValidUser(data) {
        return data.uid == request.auth.uid 
          && data.email is string && data.email.size() < 100
          && data.role in ['admin', 'staff']
          && (data.name == null || (data.name is string && data.name.size() < 100));
      }

      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      
      allow update: if isSignedIn() && isOwner(userId) && isValidUser(incoming())
                     && (isAdmin() || incoming().role == existing().role)
                     && (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'signature', 'updatedAt']));
      
      allow delete: if isAdmin();
      allow write: if isAdmin(); // Admin can manage all
    }

    // Patients
    match /patients/{patientId} {
      allow get, list: if isSignedIn();
      
      function isValidPatient(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() < 200
          && data.receptionistId == request.auth.uid
          && data.gender in ['Masculino', 'Feminino', 'Outro']
          && data.age is int && data.age >= 0 && data.age < 150
          && (data.occurrenceType == null || (data.occurrenceType is string && data.occurrenceType.size() < 500));
      }

      allow create: if isSignedIn() && isValidPatient(incoming());
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isValidPatient(incoming()) && incoming().receptionistId == existing().receptionistId)
      );
      
      allow delete: if isAdmin();
    }

    // Doctors
    match /doctors/{doctorId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Counters for sequential IDs
    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }

    // Authorization Whitelist
    match /authorized_users/{email} {
      // Any signed in user can check their own authorization during login
      // but only admin can see the full list
      allow get: if isSignedIn(); 
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // Backups
    match /backups/{backupId} {
      allow read, write: if isAdmin();
    }
  }
}
